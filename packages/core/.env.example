# Database (Lox defaults)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=lox_brain
DB_USER=lox
PG_PASSWORD=changeme_in_prod

# OpenAI (embeddings)
OPENAI_API_KEY=changeme_in_prod

# Vault
VAULT_PATH=/path/to/your/vault

# MCP Transport (default: stdio for personal mode)
# MCP_TRANSPORT=http
# MCP_PORT=3100
# MCP_HOST=127.0.0.1

# Team mode (set by installer for team deployments)
# LOX_MODE=team
# LOX_LICENSE_PUBLIC_KEY=<loaded from /etc/lox/license-public.pem>
